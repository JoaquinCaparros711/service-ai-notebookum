# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=production

# ─── NVIDIA NIM (API de IA) ───────────────────────────────────────────────────
# ⚠ CAMBIAR: obtené tu clave en https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://integrate.api.nvidia.com/v1
SUMMARY_MODEL=nvidia/nemotron-3-ultra-550b-a55b
CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ─── Redis ───────────────────────────────────────────────────────────────────
# ⚠ CAMBIAR: debe coincidir con REDIS_PASSWORD del docker-compose de Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── URL de Persistencia ──────────────────────────────────────────────────────
PERSISTENCE_URL=http://persistence-java.universidad.localhost:8080
